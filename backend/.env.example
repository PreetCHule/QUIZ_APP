# Example environment variables for QUIZ_APP
# Copy this file to `backend/.env` and fill values before running

SECRET_KEY=change_me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (for SQLite the default Django settings may be used)
DATABASE_URL=sqlite:///db.sqlite3

# API keys (placeholders)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Add other keys your project requires below
# EXAMPLE_KEY=replace_with_value
